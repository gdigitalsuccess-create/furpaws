# ─── Supabase ──────────────────────────────────────────────────────────────────
# Créer un projet sur https://supabase.com et copier les clés
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Créer un compte sur https://stripe.com
# Utiliser les clés TEST pendant le développement, LIVE en production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend (emails) ───────────────────────────────────────────────────────────
# Créer un compte sur https://resend.com et vérifier le domaine
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=orders@votredomaine.com

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Site Identity (src/config/site.config.ts) ─────────────────────────────────
NEXT_PUBLIC_SITE_NAME=MON SHOP
NEXT_PUBLIC_SITE_TAGLINE=Votre description courte
NEXT_PUBLIC_SITE_DESC=Description complète pour le SEO
NEXT_PUBLIC_CONTACT_EMAIL=hello@votredomaine.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@votredomaine.com
ADMIN_EMAIL=admin@votredomaine.com
NEXT_PUBLIC_TWITTER=@votrehandle
NEXT_PUBLIC_OG_LOCALE=en_US

# ─── Banque (paiement par virement) ────────────────────────────────────────────
BANK_NAME=Nom de la banque
BANK_ACCOUNT_NAME=Nom du titulaire
BANK_IBAN=AExx xxxx xxxx xxxx xxxx xxx
BANK_SWIFT=XXXXAEAXXX
